# Copy to .env for local development, or set these in Coolify → Environment Variables.

OPENAI_API_KEY=
PORT=4000
OPENAI_BASE_URL=https://api.openai.com/v1

CHAT_MODEL=gpt-4o
EMBED_MODEL=text-embedding-3-small

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- URLs (use your real domains in production / Coolify) ---
# API public URL (Coolify domain on the server service), e.g. https://api.yourdomain.com
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# Frontend public URL (Coolify domain on the frontend service), e.g. https://app.yourdomain.com
FRONTEND_URL=http://localhost:5173

# Baked into the frontend image at build time — must match the API public URL
VITE_API_BASE=http://localhost:4000

# --- Database ---
# Local docker-compose.yaml (bundled Postgres):
#   postgresql://flowergrid:flowergrid@postgres:5432/flowergrid?schema=public
# Local without Docker:
#   postgresql://flowergrid:flowergrid@localhost:5432/flowergrid?schema=public
# Coolify: paste the connection string from your Coolify Postgres service
DATABASE_URL=postgresql://flowergrid:flowergrid@localhost:5432/flowergrid?schema=public

SESSION_SECRET=change-me-in-production
