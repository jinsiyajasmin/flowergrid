# Copy to .env in the project root and fill in your values.
# docker compose (docker-compose.yaml) overrides DATABASE_URL and callback URLs for local containers.

OPENAI_API_KEY=
PORT=4000
OPENAI_BASE_URL=https://api.openai.com/v1

CHAT_MODEL=gpt-4o
EMBED_MODEL=text-embedding-3-small

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# Local Postgres (matches docker-compose postgres service)
DATABASE_URL=postgresql://flowergrid:flowergrid@localhost:5432/flowergrid?schema=public

FRONTEND_URL=http://localhost:5173

SESSION_SECRET=change-me-in-production
