{
    "functions": {
        "api/index.js": {
            "maxDuration": 30,
            "includeFiles": "server/kb/**"
        }
    },
    "rewrites": [
        {
            "source": "/chat",
            "destination": "/api/index.js"
        },
        {
            "source": "/auth/:path*",
            "destination": "/api/index.js"
        },
        {
            "source": "/admin/users",
            "destination": "/api/index.js"
        },
        {
            "source": "/admin/summaries",
            "destination": "/api/index.js"
        },
        {
            "source": "/health",
            "destination": "/api/index.js"
        },
        {
            "source": "/(.*)",
            "destination": "/frontend/index.html"
        }
    ]
}