# LOCAL DEV ONLY — Coolify must use repo-root Dockerfile (nginx + Express API).
FROM node:20-alpine

WORKDIR /app

# Coolify sets NODE_ENV=production on builds — fail fast instead of serving a broken site.
RUN if [ "$NODE_ENV" = "production" ]; then \
  echo "ERROR: Do not use frontend/Dockerfile.dev for production."; \
  echo "Coolify: Base Directory = repository root, Dockerfile = Dockerfile"; \
  exit 1; \
  fi

COPY package.json package-lock.json ./
RUN npm ci

COPY . .

EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "5173"]
