# Copy these names into Coolify → Environment Variables (values are yours; do not commit secrets).
# Variable names must match docker-compose.yaml exactly.

NODE_ENV=production
PORT=4000

DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

SESSION_SECRET=replace-with-long-random-string

OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
CHAT_MODEL=gpt-4o
EMBED_MODEL=text-embedding-3-small

GOOGLE_CLIENT_ID=....apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_CALLBACK_URL=https://luna.flowergrid.co.uk/api/auth/google/callback
FRONTEND_URL=https://luna.flowergrid.co.uk

# Do NOT add:
# VITE_API_BASE=http://localhost:4000
